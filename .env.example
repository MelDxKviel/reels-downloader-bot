# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Список ID администраторов (через запятую)
# Администраторы могут добавлять/удалять пользователей и видеть статистику
ADMIN_USERS=123456789,987654321

# URL базы данных PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/downloader_bot

# Директория для скачанных видео
DOWNLOAD_DIR=downloads

# Язык интерфейса по умолчанию для новых пользователей.
# Поддерживаются: ru, en. Пользователи могут выбрать свой язык командой /language.
DEFAULT_LANGUAGE=ru

# Пароль PostgreSQL (для docker-compose)
POSTGRES_PASSWORD=postgres

# Путь к файлу cookies для YouTube (для видео 18+)
# Экспортируйте cookies с youtube.com через расширение "Get cookies.txt LOCALLY"
YT_COOKIES_FILE=/app/cookies.txt

# Путь к файлу cookies для Instagram (для приватных аккаунтов/ограничений)
# Экспортируйте cookies с instagram.com через расширение "Get cookies.txt LOCALLY"
INSTA_COOKIES_FILE=/app/instagram-cookies.txt

# ID чата для промежуточной загрузки медиа в inline-режиме (fallback: первый ADMIN_USERS)
VIDEO_STORAGE_CHAT_ID=-1001234567890

# Пути к cookies-файлам на хосте (для docker-compose)
YT_COOKIES_FILE_HOST_PATH=./cookies/youtube.txt
INSTA_COOKIES_FILE_HOST_PATH=./cookies/instagram.txt
